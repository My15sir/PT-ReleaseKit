#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local src="$1"
  if command -v readlink >/dev/null 2>&1; then
    local resolved=""
    resolved="$(readlink -f "$src" 2>/dev/null || true)"
    if [[ -n "$resolved" ]]; then
      echo "$resolved"
      return 0
    fi
  fi
  local dir=""
  while [[ -L "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  echo "$src"
}

show_error() {
  local message="$1"
  if command -v zenity >/dev/null 2>&1; then
    zenity --error --title="PT-BDtool" --text="$message" >/dev/null 2>&1 || true
  elif command -v kdialog >/dev/null 2>&1; then
    kdialog --error "$message" >/dev/null 2>&1 || true
  elif command -v osascript >/dev/null 2>&1; then
    osascript -e "display alert \"PT-BDtool\" message \"${message//\"/\\\"}\" as critical" >/dev/null 2>&1 || true
  fi
  printf '[ERROR] %s\n' "$message" >&2
}

run_with_python() {
  local py_cmd="$1"
  shift || true
  command -v "$py_cmd" >/dev/null 2>&1 || return 1
  [[ -f "$SCRIPT_DIR/ptbd-gui.py" ]] || return 1
  if ! "$py_cmd" -c "import tkinter" >/dev/null 2>&1; then
    show_error "检测到 Python，但缺少 tkinter 图形组件。Linux 常见修复是安装 python3-tk 后再重试。"
    exit 1
  fi
  exec "$py_cmd" "$SCRIPT_DIR/ptbd-gui.py" "$@"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

run_with_python python3 "$@" || true
run_with_python python "$@" || true
show_error "找不到可用的 Python 解释器或 ptbd-gui.py。请确认你是在完整的 PT-BDtool 目录里运行，并且本机已安装 Python 3。"
exit 1
