#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local src="$1"
  if command -v readlink >/dev/null 2>&1; then
    local resolved=""
    resolved="$(readlink -f "$src" 2>/dev/null || true)"
    if [[ -n "$resolved" ]]; then
      printf '%s\n' "$resolved"
      return 0
    fi
  fi
  local dir=""
  while [[ -L "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  printf '%s\n' "$src"
}

find_app_root() {
  local script_dir="$1"
  local candidate=""
  local -a candidates=()
  [[ -n "${PTBDTOOL_ROOT:-}" ]] && candidates+=("$PTBDTOOL_ROOT")
  [[ -n "${PTBD_INSTALL_ROOT:-}" ]] && candidates+=("$PTBD_INSTALL_ROOT")
  candidates+=("$script_dir" "$script_dir/.." "/opt/PT-BDtool")
  [[ -n "${HOME:-}" ]] && candidates+=("$HOME/.local/share/pt-bdtool/PT-BDtool-app")
  for candidate in "${candidates[@]}"; do
    [[ -n "$candidate" ]] || continue
    if [[ -f "$candidate/ptbd_core/cli.py" && -x "$candidate/bdtool-legacy.sh" ]]; then
      (cd -P "$candidate" && pwd)
      return 0
    fi
  done
  return 1
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]:-$0}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
APP_ROOT="$(find_app_root "$SCRIPT_DIR" || true)"
[[ -n "$APP_ROOT" ]] || APP_ROOT="$SCRIPT_DIR"
LEGACY_BIN="$APP_ROOT/bdtool-legacy.sh"

run_legacy() {
  [[ -x "$LEGACY_BIN" ]] || {
    echo "[ERROR] PT-BDtool legacy fallback not found: $LEGACY_BIN" >&2
    exit 127
  }
  exec "$LEGACY_BIN" "$@"
}

case "${1:-}" in
  ""|start|install|--lang|--lang=*|--non-interactive)
    run_legacy "$@"
    ;;
esac

if [[ "${PTBD_PYTHON_CORE:-1}" == "0" ]]; then
  run_legacy "$@"
fi

PYTHON_BIN="${PTBD_PYTHON_BIN:-}"
if [[ -z "$PYTHON_BIN" ]]; then
  PYTHON_BIN="$(command -v python3 || true)"
fi
if [[ -z "$PYTHON_BIN" ]]; then
  run_legacy "$@"
fi

export PTBDTOOL_ROOT="$APP_ROOT"
export PYTHONPATH="$APP_ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec "$PYTHON_BIN" -m ptbd_core.cli "$@"
