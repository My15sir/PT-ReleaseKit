#!/usr/bin/env bash
set -euo pipefail

PTBD_EASY_CONFIG_FILE="${PTBD_EASY_CONFIG_FILE:-$HOME/.config/ptbd/config.env}"
PTBD_REMOTE_CONFIG_FILE="${PTBD_REMOTE_CONFIG_FILE:-$HOME/.config/ptbd-remote/config.env}"

resolve_script_path() {
  local src="$1"
  if command -v readlink >/dev/null 2>&1; then
    local resolved=""
    resolved="$(readlink -f "$src" 2>/dev/null || true)"
    if [[ -n "$resolved" ]]; then
      echo "$resolved"
      return 0
    fi
  fi
  local dir=""
  while [[ -L "$src" ]]; do
    dir="$(cd -P "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  echo "$src"
}

find_app_root() {
  local script_dir="$1"
  local candidate=""
  local -a candidates=(
    "${PTBDTOOL_ROOT:-}"
    "${PTBD_INSTALL_ROOT:-}"
    "$script_dir"
    "$script_dir/.."
    "/opt/PT-BDtool"
    "$HOME/.local/share/pt-bdtool/PT-BDtool-app"
  )
  for candidate in "${candidates[@]}"; do
    [[ -n "$candidate" ]] || continue
    if [[ -f "$candidate/lib/ui.sh" ]]; then
      (
        cd -P "$candidate" 2>/dev/null && pwd
      )
      return 0
    fi
  done
  return 1
}

quote_sh() {
  printf "'%s'" "$(printf '%s' "${1:-}" | sed "s/'/'\\\\''/g")"
}

SCRIPT_PATH="$(resolve_script_path "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
APP_ROOT="$(find_app_root "$SCRIPT_DIR" || true)"
[[ -n "$APP_ROOT" ]] || APP_ROOT="$SCRIPT_DIR"

REMOTE_SCRIPT="$APP_ROOT/ptbd-remote.sh"
MENU_SCRIPT="$APP_ROOT/ptbd-start.sh"

usage() {
  cat <<'EOF'
Usage:
  ptbd
  ptbd --setup
  ptbd --show-config

What it does:
  - Provides a beginner-friendly single entrypoint
  - First run asks whether you want local mode or VPS mode
  - After setup, runs the saved mode directly

Modes:
  local   Open the normal PT-BDtool menu on this machine
  remote  Open the VPS workflow and auto-return results to this machine
EOF
}

prompt_value() {
  local prompt="$1"
  local default_value="${2:-}"
  local secret="${3:-0}"
  local value=""
  if [[ "$secret" == "1" ]]; then
    read -r -s -p "$prompt" value < /dev/tty || true
    printf '\n' > /dev/tty
  else
    read -r -p "$prompt" value < /dev/tty || true
  fi
  printf '%s' "${value:-$default_value}"
}

write_easy_config() {
  mkdir -p "$(dirname "$PTBD_EASY_CONFIG_FILE")"
  cat > "$PTBD_EASY_CONFIG_FILE" <<EOF
PTBD_MODE=$(quote_sh "$PTBD_MODE")
PTBD_REMOTE_CONFIG_FILE=$(quote_sh "$PTBD_REMOTE_CONFIG_FILE")
EOF
  chmod 600 "$PTBD_EASY_CONFIG_FILE"
}

write_remote_config() {
  local host="$1"
  local port="$2"
  local password="$3"
  local save_dir="$4"
  local scan_include="$5"
  local scan_exclude="$6"
  local auto_cleanup="$7"
  local auto_bootstrap="$8"
  mkdir -p "$(dirname "$PTBD_REMOTE_CONFIG_FILE")"
  cat > "$PTBD_REMOTE_CONFIG_FILE" <<EOF
PTBD_REMOTE_HOST=$(quote_sh "$host")
PTBD_REMOTE_PORT=$(quote_sh "$port")
PTBD_REMOTE_PASSWORD=$(quote_sh "$password")
PTBD_REMOTE_PT_CMD='pt'
PTBD_REMOTE_BOOTSTRAP=$(quote_sh "$auto_bootstrap")
PTBD_LOCAL_SAVE_DIR=$(quote_sh "$save_dir")
PTBD_SCAN_INCLUDE_ROOTS=$(quote_sh "$scan_include")
PTBD_SCAN_EXCLUDE_ROOTS=$(quote_sh "$scan_exclude")
PTBD_AUTO_CLEANUP=$(quote_sh "$auto_cleanup")
EOF
  chmod 600 "$PTBD_REMOTE_CONFIG_FILE"
}

resolve_default_save_dir() {
  if [[ -d "$HOME/Desktop" ]]; then
    printf '%s' "$HOME/Desktop"
    return 0
  fi
  if [[ -d "$HOME/桌面" ]]; then
    printf '%s' "$HOME/桌面"
    return 0
  fi
  mkdir -p "$HOME/Desktop"
  printf '%s' "$HOME/Desktop"
}

load_easy_config() {
  [[ -f "$PTBD_EASY_CONFIG_FILE" ]] || return 0
  # shellcheck disable=SC1090
  source "$PTBD_EASY_CONFIG_FILE"
}

show_config() {
  load_easy_config
  echo "Current beginner config"
  echo "  config file:     $PTBD_EASY_CONFIG_FILE"
  echo "  mode:            ${PTBD_MODE:-<unset>}"
  echo "  remote config:   ${PTBD_REMOTE_CONFIG_FILE:-<unset>}"
  if [[ -n "${PTBD_REMOTE_CONFIG_FILE:-}" && -f "${PTBD_REMOTE_CONFIG_FILE:-}" ]]; then
    echo "  remote config:   exists"
  fi
}

run_setup() {
  local default_save_dir=""
  default_save_dir="$(resolve_default_save_dir)"
  local mode=""

  echo "PT-BDtool 新手模式首次配置"
  echo "这个向导会帮你保存以后要用的模式。"
  echo
  echo "1) 本机处理（本机扫描，本机出结果）"
  echo "2) VPS 处理（本机控制 VPS，结果自动回本机）"
  mode="$(prompt_value "请选择模式 [2]: " "2")"

  case "$mode" in
    1|local|LOCAL)
      PTBD_MODE="local"
      write_easy_config
      echo "已保存为本机模式。以后直接运行：ptbd"
      ;;
    2|remote|REMOTE|vps|VPS)
      PTBD_MODE="remote"
      local host="" port="" auth_mode="" password="" scan_include="" scan_exclude="" save_dir="" auto_cleanup="" auto_bootstrap=""
      host="$(prompt_value "VPS 地址（如 root@1.2.3.4）: " "${PTBD_REMOTE_HOST:-root@your-vps}")"
      port="$(prompt_value "SSH 端口 [22]: " "22")"
      auth_mode="$(prompt_value "认证方式 key / password [password]: " "password")"
      if [[ "$auth_mode" == "password" ]]; then
        password="$(prompt_value "SSH 密码: " "" "1")"
      else
        password=""
      fi
      auto_bootstrap="$(prompt_value "空白 VPS 自动自举？1=是 0=否 [1]: " "1")"
      scan_include="$(prompt_value "默认扫描目录（留空=智能扫描常见目录） [${PTBD_SCAN_INCLUDE_ROOTS:-}]: " "${PTBD_SCAN_INCLUDE_ROOTS:-}")"
      scan_exclude="$(prompt_value "额外排除目录（可留空） []: " "${PTBD_SCAN_EXCLUDE_ROOTS:-}")"
      save_dir="$(prompt_value "本机保存目录 [$default_save_dir]: " "$default_save_dir")"
      auto_cleanup="$(prompt_value "处理后自动清理 VPS 生成目录？1=是 0=否 [1]: " "1")"
      write_remote_config "$host" "$port" "$password" "$save_dir" "$scan_include" "$scan_exclude" "$auto_cleanup" "$auto_bootstrap"
      write_easy_config
      echo "已保存为 VPS 模式。以后直接运行：ptbd"
      ;;
    *)
      echo "输入无效，未保存。"
      return 1
      ;;
  esac
}

run_mode() {
  load_easy_config
  if [[ -z "${PTBD_MODE:-}" ]]; then
    run_setup
    load_easy_config
  fi

  case "${PTBD_MODE:-}" in
    local)
      exec "$MENU_SCRIPT"
      ;;
    remote)
      exec "$REMOTE_SCRIPT" --config "$PTBD_REMOTE_CONFIG_FILE"
      ;;
    *)
      echo "[ERROR] 未识别的模式：${PTBD_MODE:-<unset>}"
      echo "请重新执行：ptbd --setup"
      exit 2
      ;;
  esac
}

case "${1:-}" in
  -h|--help|help)
    usage
    exit 0
    ;;
  --setup)
    run_setup
    exit 0
    ;;
  --show-config)
    show_config
    exit 0
    ;;
  "")
    run_mode
    ;;
  *)
    usage
    exit 2
    ;;
esac
